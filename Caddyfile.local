:8080 {
    root * /Users/lennart/projects/lead-machine/frontend/dist
    encode gzip
    handle /api/* {
        reverse_proxy localhost:8000
    }
    handle {
        try_files {path} /index.html
        file_server
    }
}

# Operations Dashboard — port 3001
:3001 {
    encode gzip
    handle /api/* {
        reverse_proxy 127.0.0.1:4001
    }
    handle {
        root * /Users/lennart/projects/lead-machine/dashboard/dist
        try_files {path} /index.html
        file_server
    }
}
