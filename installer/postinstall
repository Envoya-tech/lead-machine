#!/bin/bash
# Lead Machine — postinstall
# No Terminal window. Everything runs silently in the background.
# A browser loading page tracks progress, then redirects to /setup.

INSTALL_DIR="/Applications/LeadMachine"

# ── Identify the console user ─────────────────────────────────────────────────
CONSOLE_USER=$(stat -f '%Su' /dev/console 2>/dev/null)
if [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ]; then
    CONSOLE_USER=$(dscl . -list /Users UniqueID 2>/dev/null \
        | awk '$2 >= 500 {print $1}' | head -1)
fi
[ -z "$CONSOLE_USER" ] && CONSOLE_USER="$(whoami)"

USER_HOME=$(eval echo "~$CONSOLE_USER")

# ── Hand ownership of install dir to the console user ────────────────────────
chown -R "$CONSOLE_USER" "$INSTALL_DIR" 2>/dev/null || true

# ── Pre-create log file owned by the console user (not root) ─────────────────
LOG_DIR="$USER_HOME/Library/Logs/LeadMachine"
sudo -u "$CONSOLE_USER" mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/install.log"
sudo -u "$CONSOLE_USER" touch "$LOG"

# ── Open the browser loading page immediately ─────────────────────────────────
LOADING_PAGE="$INSTALL_DIR/frontend/loading.html"
sudo -u "$CONSOLE_USER" open "$LOADING_PAGE" 2>/dev/null || true

# ── Run the silent bootstrap in the background as the console user ────────────
# bootstrap.sh manages its own log — do NOT redirect here (causes root-owned log)
sudo -u "$CONSOLE_USER" \
    LOG="$LOG" \
    bash "$INSTALL_DIR/installer/bootstrap.sh" &

exit 0
